# Database
DATABASE_URL=mysql+aiomysql://root:root@127.0.0.1:3306/oauth2_db
DATABASE_URL_SYNC=mysql+pymysql://root:root@127.0.0.1:3306/oauth2_db

# JWT - CHANGE THESE IN PRODUCTION
JWT_SECRET_KEY=change-me-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Authorization code
AUTHORIZATION_CODE_EXPIRE_MINUTES=10

# Session
SESSION_SECRET_KEY=change-me-session-secret
